{
  "manifest_version": 3,
  "name": "SpeedDial Board",
  "version": "1.0.0",
  "description": "A customizable speed dial new tab dashboard with isolated bookmark folders, an explicit grid system, and live widgets.",
  "permissions": [
    "bookmarks",
    "storage",
    "geolocation"
  ],
  "host_permissions": [
    "https://api.open-meteo.com/*",
    "https://www.google.com/*"
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
